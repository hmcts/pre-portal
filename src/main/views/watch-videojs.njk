{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% extends "template.njk" %}

{% block pageTitle %}Recording {{ recording.id }} - PRE Portal{% endblock %}

{% block head %}
  {% include "webpack/css.njk" %}
  <script type="text/javascript" src="/assets/js/video.min.js"></script>
  <script type="text/javascript" src="/assets/js/hls.min.js"></script>
  <link rel="stylesheet" href="/assets/css/video-js.min.css">
{% endblock %}

{% set bannerHtml %}
  <p class="govuk-notification-banner__heading">Recordings are accessed on the basis of a
    legitimate need and having full authorisation.</p>
  <p class="govuk-notification-banner__heading">Please note, playback is preferred
    on Laptop and Desktop devices only.</p>
{% endset %}

{% block beforeContent %}
  {{
  govukBackLink({
    "href": "javascript:history.back()"
  })
  }}
{% endblock %}

{% block content %}
  <h1 class="govuk-heading-xl">Case Ref: {{ recording.case_reference }}</h1>

  {{ govukNotificationBanner({
    html: bannerHtml
  }) }}

  <div id="videoError" class="govuk-error-summary" data-module="govuk-error-summary" style="display: none;">
    <div role="alert">
      <h2 class="govuk-error-summary__title">
        There is a problem
      </h2>
      <div class="govuk-error-summary__body">
        <ul class="govuk-list govuk-error-summary__list">
          <li class="govuk-error-message">
            The recording is not currently available
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div id="loading" class="govuk-!-margin-bottom-2 loading-box" style="display: block;">
    <div class="loading-container">
      <img src="/assets/images/loading-spinner.gif" alt="Loading" />
    </div>
  </div>

  <div id="videoWrapper" class="govuk-!-margin-bottom-2 video-wrapper" style="display: none;">
    <video
      id="recording-video"
      class="video-js vjs-default-skin vjs-big-play-centered"
      controls
      preload="auto"
      playsinline
      aria-label="Recording playback"
    ></video>
  </div>

  <div class="govuk-warning-text">
    <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
    <strong class="govuk-warning-text__text">
      <span class="govuk-warning-text__assistive">Please note</span>
      playback is preferred on non-mobile devices. If possible, please use a
      preferred device.
    </strong>
  </div>

  <h2 class="govuk-heading-m">Recording details</h2>
  <dl class="govuk-summary-list govuk-!-margin-bottom-9">
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key" data-testid="summary-title-date">
        Date
      </dt>
      <dd
        class="govuk-summary-list__value"
        data-testid="summary-value-date">
        {{ recording.capture_session.started_at | formatDate }}
      </dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key" data-testid="summary-title-uid">
        Recording UID
      </dt>
      <dd class="govuk-summary-list__value" data-testid="summary-value-uid">
        {{ recording.id }}
      </dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt
        class="govuk-summary-list__key"
        data-testid="summary-title-version">
        Recording Version
      </dt>
      <dd
        class="govuk-summary-list__value"
        data-testid="summary-value-version">
        {{ recording.version }}
      </dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key" data-testid="summary-title-court">
        Court
      </dt>
      <dd
        class="govuk-summary-list__value"
        data-testid="summary-value-court">
        {{ recording.capture_session.court_name }}
      </dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt
        class="govuk-summary-list__key"
        data-testid="summary-title-witness">
        Witness
      </dt>

      <dd
        class="govuk-summary-list__value"
        data-testid="summary-value-witness">
        {% for participant in recording.participants %}
          {% if participant.participant_type == "WITNESS" %}
            {{ participant.first_name }}<br />
          {% endif %}
        {% endfor %}
      </dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt
        class="govuk-summary-list__key"
        data-testid="summary-title-defendants">
        Defendants
      </dt>
      <dd
        class="govuk-summary-list__value"
        data-testid="summary-value-defendants">
        {% for participant in recording.participants %}
          {% if participant.participant_type == "DEFENDANT" %}
            {{ participant.first_name }} {{ participant.last_name }}<br />
          {% endif %}
        {% endfor %}
      </dd>
    </div>
  </dl>
  <script type="text/javascript" crossorigin="anonymous" data-testid="recording-video-script">
    const videoElement = document.getElementById("recording-video");
    const videoError = document.getElementById("videoError");
    const loading = document.getElementById("loading");
    const videoWrapper = document.getElementById("videoWrapper");
    let hlsPlayer;
    let player;

    function hideLoading() {
      loading.style.display = "none";
    }

    function showPlayer() {
      hideLoading();
      videoWrapper.style.display = "block";
    }

    function disposePlayers() {
      if (hlsPlayer) {
        hlsPlayer.destroy();
        hlsPlayer = null;
      }

      if (player) {
        player.dispose();
        player = null;
      }
    }

    function showError(error) {
      console.error("Error:", error);
      disposePlayers();
      videoError.style.display = "block";
      videoWrapper.style.display = "none";
      hideLoading();
    }

    function extractAuthorisationHeader(data) {
      if (typeof data.authorization === "string" && data.authorization.length > 0) {
        return data.authorization;
      }

      if (data.headers && typeof data.headers.Authorization === "string" && data.headers.Authorization.length > 0) {
        return data.headers.Authorization;
      }

      if (typeof data.token === "string" && data.token.length > 0) {
        return "Bearer=" + data.token;
      }

      if (!Array.isArray(data.protectionInfo)) {
        return "";
      }

      for (const entry of data.protectionInfo) {
        if (!entry || typeof entry !== "object") {
          continue;
        }

        if (typeof entry.Authorization === "string" && entry.Authorization.length > 0) {
          return entry.Authorization;
        }

        if (entry.headers && typeof entry.headers === "object") {
          if (typeof entry.headers.Authorization === "string" && entry.headers.Authorization.length > 0) {
            return entry.headers.Authorization;
          }
        }

        if (typeof entry.token === "string" && entry.token.length > 0) {
          return "Bearer=" + entry.token;
        }
      }

      return "";
    }

    function normalisePlaybackData(data) {
      return {
        hlsUrl: data.hls_url || data.src || "",
        authorization: extractAuthorisationHeader(data),
      };
    }

    function isClearKeyRequestUrl(url) {
      return typeof url === "string" && url.indexOf("/drm/clear-key") !== -1;
    }

    function createVideoPlayer(playbackData) {
      player = window.videojs(videoElement, {
        autoplay: false,
        controls: true,
        fluid: true,
        muted: false,
        preload: "auto",
        responsive: true,
        controlBar: {
          pictureInPictureToggle: false,
        },
      });

      if (window.Hls && window.Hls.isSupported()) {
        hlsPlayer = new window.Hls({
          enableWorker: true,
          xhrSetup: function (xhr, url) {
            if (playbackData.authorization && isClearKeyRequestUrl(url)) {
              xhr.setRequestHeader("Authorization", playbackData.authorization);
            }
          },
          fetchSetup: function (context, initParams) {
            const headers = new Headers((initParams && initParams.headers) || {});

            if (playbackData.authorization && context && isClearKeyRequestUrl(context.url)) {
              headers.set("Authorization", playbackData.authorization);
            }

            return new Request(context.url, {
              ...initParams,
              credentials: "same-origin",
              headers,
            });
          },
        });

        hlsPlayer.on(window.Hls.Events.MANIFEST_PARSED, function () {
          showPlayer();
        });
        hlsPlayer.on(window.Hls.Events.ERROR, function (_event, data) {
          if (data && data.fatal) {
            showError(data);
          }
        });
        hlsPlayer.loadSource(playbackData.hlsUrl);
        hlsPlayer.attachMedia(videoElement);
        return;
      }

      if (videoElement.canPlayType("application/vnd.apple.mpegurl")) {
        if (playbackData.authorization) {
          throw new Error("Protected HLS playback requires hls.js support in this browser.");
        }

        videoElement.src = playbackData.hlsUrl;
        videoElement.addEventListener("loadedmetadata", showPlayer, { once: true });
        return;
      }

      throw new Error("HLS playback is not supported in this browser.");
    }

    fetch("{{ recordingPlaybackDataUrl }}", {
      method: "GET",
      headers: {
        "Content-Type": "application/json",
      },
    }).then(function (response) {
      if (!response.ok) {
        throw new Error(response);
      }

      return response.json();
    }).then(async function (data) {
      const playbackData = normalisePlaybackData(data);

      if (!playbackData.hlsUrl) {
        throw new Error("Missing HLS playback URL.");
      }

      // wait for the url to be available
      let hlsAvailable = false;
      let retries = 120;
      let time = 3000;
      do {
        await new Promise(r => setTimeout(r, time)); // sleep for `time`ms
        const headResult = await fetch(playbackData.hlsUrl, {
          method: "HEAD",
        });
        hlsAvailable = headResult.status === 200;
        retries--;
        time -= 1000;
        if (time < 1000) {
          time = 500;
        }
      } while (hlsAvailable === false && retries > 0);

      if (!hlsAvailable) {
        throw new Error("The HLS stream did not become available in time.");
      }

      createVideoPlayer(playbackData);
    }).catch(function (error) {
      showError(error);
    });

    window.addEventListener("beforeunload", disposePlayers);
  </script>
{% endblock %}
